# ------------------------------
# Jobs / Cron
# ------------------------------
CONTEST_SYNC_CRON=0 */6 * * *
STATUS_UPDATE_CRON=*/5 * * * *
REMINDER_CHECK_CRON=*/5 * * * *
REMINDER_TIME_BEFORE=15
REMINDER_CHECK_INTERVAL=5
PROFILE_SYNC_CRON=0 */6 * * *
ACCOUNT_REVALIDATION_CRON=0 0 * * *
MAINTENANCE_CRON=0 3 * * *

# ------------------------------
# Verification / profile sync
# ------------------------------
ACCOUNT_VERIFICATION_TTL_DAYS=90
VERIFICATION_REVALIDATION_DAYS=90
VERIFICATION_PENDING_TTL_MINUTES=15
COMPETITIVE_PROFILE_CACHE_TTL_SECONDS=7200
COMPETITIVE_PROFILE_SYNC_INTERVAL_HOURS=6
COMPETITIVE_PROFILE_MANUAL_SYNC_COOLDOWN_SECONDS=60
COMPETITIVE_PROFILE_SYNC_LOCK_TTL_SECONDS=120
COMPETITIVE_PROFILE_SYNC_MAX_REQUESTS_PER_MINUTE=5
COMPETITIVE_PROFILE_SYNC_RATE_WINDOW_SECONDS=60
COMPETITIVE_PROFILE_SYNC_FAILURE_RETRY_SECONDS=30
LEETCODE_PROFILE_CACHE_TTL_SECONDS=600
LEETCODE_TIMEOUT_MS=5000
LEETCODE_RETRIES=2
LEETCODE_RETRY_DELAY_MS=500
